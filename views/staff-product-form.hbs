<div class="page-container">
  <div class="page-header">
    <a href="/staff/products" class="back-link">Back to Staff Products</a>
    <h1 class="page-title">{{title}}</h1>
    <p class="page-subtitle">Keep product details complete so the shop, cart, and staff order tools stay in sync.</p>
  </div>

  {{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}

  <form method="POST" action="{{action}}" class="staff-form">
    <section class="form-section">
      <h2 class="form-section-title">Product details</h2>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Name</label>
          <input type="text" name="name" class="form-input" value="{{product.name}}" required>
        </div>
        <div class="form-group">
          <label class="form-label">Price</label>
          <input type="number" name="price" class="form-input" value="{{product.price}}" min="0.01" step="0.01" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Category</label>
          <input type="text" name="category" class="form-input" value="{{product.category}}" list="category-options" required>
          <datalist id="category-options">
            {{#each categories}}<option value="{{this}}"></option>{{/each}}
          </datalist>
        </div>
        <div class="form-group">
          <label class="form-label">Type</label>
          <input type="text" name="type" class="form-input" value="{{product.type}}" list="type-options" required>
          <datalist id="type-options">
            {{#each types}}<option value="{{this}}"></option>{{/each}}
          </datalist>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Image path</label>
          <input type="text" name="image" class="form-input" value="{{product.image}}" placeholder="/images/red-tshirt.svg">
        </div>
        <div class="form-group">
          <label class="form-label">Badge</label>
          <input type="text" name="badge" class="form-input" value="{{product.badge}}" placeholder="New, Sale, Limited">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea name="desc" class="form-input form-textarea">{{product.desc}}</textarea>
      </div>
    </section>

    <button type="submit" class="btn-primary btn-large">{{#if isEdit}}Save Changes{{else}}Create Product{{/if}}</button>
  </form>
</div>
